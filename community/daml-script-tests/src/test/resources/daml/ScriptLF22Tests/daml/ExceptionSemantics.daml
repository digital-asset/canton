module ExceptionSemantics where

import Daml.Script
import DA.Exception
import DA.Assert ((===))

exception E
  where
    message "E"

template K
  with
    p : Party
    v : Int
  where
    signatory p

    choice ConsumingExercise : ()
      controller p
      do pure ()

template T
  with
    p : Party
  where
    signatory p
    nonconsuming choice Throw : ()
      controller p
      do throw E
    nonconsuming choice Catch : ()
      controller p
      do try (exercise self Throw)
         catch
           E -> pure ()

    nonconsuming choice ThrowArithmeticError : Int
      controller p
      do pure (1/0)
    nonconsuming choice CatchArithmeticError : Int
      controller p
      do try (exercise self ThrowArithmeticError)
         catch
           (_: ArithmeticError) -> pure 42

    nonconsuming choice UncatchableTry : ()
      with
        cid : ContractId K
      controller p
      do try (() <$ fetch cid)
         catch
           E -> pure()

    nonconsuming choice RollbackArchive : ()
      with
        i : Int
      controller p
      do cid <- create (K p i)
         try (archive cid >> throw E)
         catch
           E -> archive cid

    nonconsuming choice NonRollbackArchive : ()
      with
        i : Int
      controller p
      do cid <- create (K p i)
         try (archive cid)
         catch
           E -> pure ()
         archive cid

    nonconsuming choice RollbackConsumingExercise : ()
      with
        i : Int
      controller p
      do cid <- create (K p i)
         try (exercise cid ConsumingExercise >> throw E)
         catch
           E -> archive cid

    nonconsuming choice NonRollbackConsumingExercise : ()
      with
        i : Int
      controller p
      do cid <- create (K p i)
         try (exercise cid ConsumingExercise)
         catch
           E -> pure ()
         exercise cid ConsumingExercise

    nonconsuming choice RollbackCreate : ()
      with
        i : Int
      controller p
      do try do
           cid <- create (K p i)
           throw E
           pure ()
         catch
           E -> pure ()

uncaughtUserException = script do
  p <- allocateParty "p-ExceptionSemantics:uncaughtUserException"
  _ <- submitMustFail p $ createAndExerciseCmd (T p) Throw
  pure ()

unhandledUserException = script do
  p <- allocateParty "p-ExceptionSemantics:unhandledUserException"
  _ <- submit p $ createAndExerciseCmd (T p) Throw
  pure ()

handledUserException = script do
  p <- allocateParty "p-ExceptionSemantics:handledUserException"
  _ <- submit p $ createAndExerciseCmd (T p) Catch
  pure ()

uncaughtArithmeticError = script do
  p <- allocateParty "p-ExceptionSemantics:uncaughtArithmeticError"
  _ <- submitMustFail p $ createAndExerciseCmd (T p) ThrowArithmeticError
  pure ()

unhandledArithmeticError = script do
  p <- allocateParty "p-ExceptionSemantics:unhandledArithmeticError"
  _ <- submit p $ createAndExerciseCmd (T p) ThrowArithmeticError
  pure ()

handledArithmeticError = script do
  p <- allocateParty "p-ExceptionSemantics:handledArithmeticError"
  r <- submit p $ createAndExerciseCmd (T p) CatchArithmeticError
  r === 42

rollbackArchive = script do
  p <- allocateParty "p-ExceptionSemantics:rollbackArchive"
  submitMustFail p $ createAndExerciseCmd (T p) (NonRollbackArchive 0)
  submit p $ createAndExerciseCmd (T p) (RollbackArchive 0)

rollbackConsumingExercise = script do
  p <- allocateParty "p-ExceptionSemantics:rollbackConsumingExercise"
  submitMustFail p $ createAndExerciseCmd (T p) (NonRollbackConsumingExercise 0)
  submit p $ createAndExerciseCmd (T p) (RollbackConsumingExercise 0)

rollbackCreate = script do
  p <- allocateParty "p-ExceptionSemantics:rollbackCreate"
  submit p $ createAndExerciseCmd (T p) (RollbackCreate 0)

tryContext = script do
  p <- allocateParty "p-ExceptionSemantics:tryContext"
  kCid <- submit p $ createCmd (K p 0)
  submit p $ archiveCmd kCid
  c <- submit p $ createCmd (T p)
  -- This will result in a partial transaction with ptx.context.info
  -- pointing to a TryContextInfo.
  submit p $ exerciseCmd c (UncatchableTry kCid)
