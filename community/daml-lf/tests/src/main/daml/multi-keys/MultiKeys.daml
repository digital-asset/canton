module MultiKeys where

import DA.Assert
import DA.ContractKeys
import DA.Exception (throw)
import DA.Optional

exception E
  where
    message "E"

exception EWith with
    cids : [(ContractId Keyed, Keyed)]
  where
    message "EWithCids"

template Keyed
  with
    p : Party
  where
    signatory p
    key p : Party
    maintainer key

-- All these tests operate under the assumption that there
-- exists two global contracts with the same key `p` and one
-- of those will always be returned by fetch/lookup-by-key at
-- the beginning of the choice.
-- All choices here are accepted in non-uck (unique contract key) mode.
-- Behavior in uck-mode is documented in comments.
-- Note that uck-mode here refers to the uck mode in the engine
-- (not yet implemented, TODO(#30144) MK: remove this comment once it is) which only detects
-- a subset of unique key errors.
-- Note: At the moment, we do not provide any stability guarantees for
-- non-uck at this point so these tests serve only as an indication of the
-- current behavior and can be changed freely.
template KeyOperations
  with
    p : Party
  where
    signatory p

    nonconsuming choice CreateOverwritesLocal : ()
      controller p
      do cid1 <- create (Keyed p)
         cid2 <- create (Keyed p)
         (cid, _) <- fetchByKey @Keyed p
         cid2 === cid

    nonconsuming choice CreateOverwritesUnknownGlobal : ()
      controller p
      do -- assume the global exists but do not fetch it
         cid1 <- create (Keyed p)
         (cid, _) <- fetchByKey @Keyed p
         cid1 === cid

    nonconsuming choice CreateOverwritesKnownGlobal : ()
      controller p
      do _ <- fetchByKey @Keyed p
         cid1 <- create (Keyed p)
         (cid, _) <- fetchByKey @Keyed p
         cid1 === cid

    nonconsuming choice FetchDoesNotOverwriteGlobal : ()
      with
        cid : ContractId Keyed
      controller p
      do (cidByKey, _) <- fetchByKey @Keyed p
         cid =/= cidByKey -- sanity-check the choice argument
         c <- fetch cid
         key c === p
         (cidByKey', _) <- fetchByKey @Keyed p
         cidByKey' === cidByKey

    nonconsuming choice FetchDoesNotOverwriteLocal : ()
      with
        cid : ContractId Keyed
      controller p
      do local <- create (Keyed p)
         c <- fetch cid
         key c === p
         (cid', _) <- fetchByKey @Keyed p
         local === cid'

    nonconsuming choice LocalArchivePreservesUnknownGlobal : ()
      controller p
      do
         local <- create (Keyed p)
         archive local
         after <- lookupByKey @Keyed p
         after =/= Some local
         pure ()

    nonconsuming choice LocalArchivePreservesKnownGlobal : ()
      controller p
      do before <- lookupAllByKey @Keyed p
         local <- create (Keyed p)
         archive local
         after <- lookupAllByKey @Keyed p
         after === before
         pure ()

    nonconsuming choice GlobalArchivePreservesUnknownGlobal : ()
      with
        cid1 : ContractId Keyed
        cid2 : ContractId Keyed
      controller p
      do cid1 =/= cid2
         c1 <- fetch cid1
         key c1 === p
         c2 <- fetch cid2
         key c2 === p
         archive cid1
         after <- lookupAllByKey @Keyed p
         assert (not (any (\(c, _) -> c == cid1) after))
         pure ()

    nonconsuming choice GlobalArchivePreservesKnownGlobal1 : ()
      with
        cid1 : ContractId Keyed
        cid2 : ContractId Keyed
      controller p
      do cid1 =/= cid2
         c1 <- fetch cid1
         key c1 === p
         c2 <- fetch cid2
         key c2 === p
         (keyCid, _) <- fetchByKey @Keyed p
         assert (keyCid `elem` [cid1, cid2])
         archive (fromSome (find (/= keyCid) [cid1, cid2]))
         -- archive can only influence result for a contract fetched by key before.
         after <- lookupAllByKey @Keyed p
         assert (any (\(c, _) -> c == keyCid) after)
         pure ()

    nonconsuming choice GlobalArchivePreservesKnownGlobal2 : ()
      with
        cid1 : ContractId Keyed
        cid2 : ContractId Keyed
      controller p
      do cid1 =/= cid2
         c1 <- fetch cid1
         key c1 === p
         c2 <- fetch cid2
         key c2 === p
         (keyCid, _) <- fetchByKey @Keyed p
         assert (keyCid `elem` [cid1, cid2])
         archive keyCid
         let otherCid = fromSome (find (/= keyCid) [cid1, cid2])
         after <- lookupAllByKey @Keyed p
         assert (any (\(c, _) -> c == otherCid) after)
         pure ()

    nonconsuming choice RollbackCreate : ()
      controller p
      do cid1 <- fetchByKey @Keyed p
         try do
           cid <- create (Keyed p)
           (cid', _) <- fetchByKey @Keyed p
           cid === cid'
           throw E
         catch E -> pure ()

    nonconsuming choice RollbackLocalArchive : ()
      controller p
      do local <- create (Keyed p)
         try do
           archive local
           throw E
         catch E -> pure ()

    nonconsuming choice RollbackFetchByKeyNonRollbackCreate : ()
      controller p
      do try do
           _ <- fetchByKey @Keyed p
           throw E
         catch E -> pure ()
         cid <- create (Keyed p)
         (cid', _) <- fetchByKey @Keyed p
         cid === cid'

    nonconsuming choice RollbackFetchNonRollbackCreate : ()
      with
        cid : ContractId Keyed
      controller p
      do try do
           c <- fetch cid
           key c === p
           throw E
         catch E -> pure ()
         cid <- create (Keyed p)
         (cid', _) <- fetchByKey @Keyed p
         cid === cid'

    nonconsuming choice RollbackGlobalArchive : ()
      with
        cid1 : ContractId Keyed
        cid2 : ContractId Keyed
      controller p
      do (cid', _) <- fetchByKey @Keyed p
         cid1 === cid'
         try do
           archive cid2
           throw E
         catch
           E -> pure ()

     --  regression test for https://github.com/digital-asset/daml/pull/14080
    nonconsuming choice RollbackGlobalArchivedLookup : ()
        with
          cid: ContractId Keyed
        controller p
        do
          archive cid
          result' <- try do
            result' <- lookupAllByKey @Keyed p
            throw (EWith result')
          catch (EWith result') -> pure result'
          result <- lookupAllByKey @Keyed p
          result === result'
          pure ()

    --  regression test for https://github.com/digital-asset/daml/pull/14080
    choice RollbackGlobalArchivedCreate : ()
      with
        cid : ContractId Keyed
      controller p
      do
         archive cid
         result' <- try do
            result' <- lookupAllByKey @Keyed p
            throw (EWith result')
         catch (EWith result') -> pure result'
         cid <- create (Keyed p)
         result <- lookupAllByKey @Keyed p
         result === (cid, Keyed p) :: result'
         pure ()


-- This template is used to test that the
-- engine only ever looks up a global key once.
-- All choices should succeed under the assumption
-- that there is one global contract with key p
template GlobalLookups
  with
    p : Party
  where
    signatory p

    choice LookupTwice : ()
      controller p
      do Some _ <- lookupByKey @Keyed p
         Some _ <- lookupByKey @Keyed p
         pure ()

    choice LookupAfterCreate : ()
      controller p
      do cid <- create (Keyed p)
         Some cid' <- lookupByKey @Keyed p
         cid === cid'
         pure ()

    choice LookupAfterCreateArchive : ()
      controller p
      do cid <- create (Keyed p)
         Some cid' <- lookupByKey @Keyed p
         cid === cid'
         pure ()

    choice LookupAfterFetch : ()
      with
        cid : ContractId Keyed
      controller p
      do -- Fetch does not bring key in scope.
         c <- fetch cid
         key c === p
         Some _ <- lookupByKey @Keyed p
         pure ()

    choice LookupAfterArchive : ()
      with
        cid : ContractId Keyed
      controller p
      do -- Archive does not bring key in scope.
         c <- fetch cid
         key c === p
         archive cid
         None <- lookupByKey @Keyed p
         pure ()

    -- Note that this will be rejected by
    -- the unique contract key check in the ledger
    -- but not by the engine.
    choice LookupAfterRollbackCreate : ()
      controller p
      do try do
           cid <- create (Keyed p)
           throw E
         catch
           E -> pure ()
         None <- lookupByKey @Keyed p
         pure ()

    choice LookupAfterRollbackLookup : ()
      controller p
      do try do
           cid <- lookupByKey @Keyed p
           throw E
         catch
           E -> pure ()
         Some _ <- lookupByKey @Keyed p
         pure ()

    choice LookupAfterArchiveAfterRollbackLookup : ()
      with
        cid : ContractId Keyed
      controller p
      do try do
           -- this updates globalKeyInputs
           Some cid' <- lookupByKey @Keyed p
           cid === cid'
           throw E
         catch
           E -> pure ()
         c <- fetch cid
         key c === p
         -- keys is empty here so archive does not drop it.
         archive cid
         -- this one needs to check activeness for an entry in globalKeyInputs
         None <- lookupByKey @Keyed p
         pure ()
