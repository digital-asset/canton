-- TODO(#30144): https://github.com/digital-asset/daml/issues/18457 split this daml
-- file into tempates that use keys and those that don't. Split the
-- corresponding test.

{-# LANGUAGE CPP #-}

module Exceptions where

#ifdef DAML_CONTRACT_KEYS
import DA.Assert
#endif
import DA.Exception (throw,throwPure)

exception E
  where
    message "E"

exception Ecid with cid: ContractId T
  where
    message "Ecid"

template T
  with
    p : Party
    v : Int
    t : Text
  where
    signatory p

#ifdef DAML_CONTRACT_KEYS
template K
  with
    p : Party
    v : Int
    t : Text
  where
    signatory p
    key (p, v) : (Party, Int)
    maintainer key._1
#endif

data Rollback = NoException | Throw

template Helper
  with
    p : Party
  where
    signatory p

    nonconsuming choice RollbackArchiveTransient : ()
      with
        i : Int
      controller p
      do cid <- create (T p i "")
         try (archive cid >> throw E)
         catch
           E -> pure ()
         archive cid

    nonconsuming choice ArchiveTransient : ()
      with
        i : Int
      controller p
      do cid <- create (T p i "")
         try archive cid >> pure ()
         catch
           E -> pure ()
         archive cid

    nonconsuming choice RollbackArchiveNonTransient : ()
      with
        cid : ContractId T
      controller p
      do try archive cid >> throw E
         catch
           E -> pure ()
         archive cid

    nonconsuming choice ArchiveNonTransient : ()
      with
        cid : ContractId T
      controller p
      do try archive cid >> pure ()
         catch
           E -> pure ()
         archive cid

#ifdef DAML_CONTRACT_KEYS
    nonconsuming choice RollbackKey : ()
      with
        i : Int
      controller p
      do cid <- create (K p i "before")
         try do
           archive cid
           create (K p i "rollback")
           throw E
         catch
           E -> pure ()
         (_, k) <- fetchByKey @K (p, i)
         k === K p i "before"
#endif

#ifdef DAML_CONTRACT_KEYS
    nonconsuming choice Key : ()
      with
        i : Int
      controller p
      do cid <- create (K p i "before")
         try archive cid >> create (K p i "rollback") >> pure ()
         catch
           E -> pure ()
         (_, k) <- fetchByKey @K (p, i)
         k === K p i "rollback"
#endif

    nonconsuming choice ExerciseAfterRollbackCreate: ()
      controller p
      do
        try do
          cid <- create (T p 1 "")
          throw (Ecid cid)
        catch (Ecid cid) -> archive cid

    nonconsuming choice ThrowInHandler : ()
      controller p
      do
        try
          try throw E
          catch E -> throw E
        catch
          E -> pure ()

    nonconsuming choice ThrowPureInHandler : ()
      controller p
      do
        try
          try throw E
          catch E -> throwPure E
        catch
          E -> pure ()

    nonconsuming choice ThrowPureInHandlerPattern : ()
      controller p
      do
        try
          try throw E
          catch E | throwPure E -> pure ()
        catch
          E -> pure ()

template NodeSeeds
  with
    p : Party
  where
    signatory p

    -- Produces a transaction with all non-key node types so we can
    -- check which produce node seed and which do not.
    choice CreateAllTypesNoKey : ()
      with
        cid : ContractId T
      controller p
      do _ <- fetch cid
         create (T p 1 "")
         try do
           _ <- fetch cid
           create (T p 2 "")
           throw E
         catch
           E -> pure ()
         pure ()

#ifdef DAML_CONTRACT_KEYS
    -- Produces a transaction with all node types so we can
    -- check which produce node seed and which do not.
    choice CreateAllTypes : ()
      with
        cid : ContractId K
      controller p
      do _ <- fetch cid
         create (K p 2000 "")
         create (K p 2000 "")
         try do
           _ <- fetch cid
           _ <- fetchByKey @K (p, 2000)
           _ <- lookupByKey @K (p, 2000)
           throw E
         catch
           E -> pure ()
         pure ()
#endif
