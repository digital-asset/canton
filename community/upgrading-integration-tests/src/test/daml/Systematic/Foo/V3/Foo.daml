module Foo where

import IBaz
import Baz
import IBar

template Foo
  with
    owner: Party
  where
    signatory owner

    choice Foo_Exe: ()
      with
        fooExeInformee: Party
        subInformee: Party
      observer fooExeInformee
      controller owner
        do
          bazCid <- create Baz with owner = owner, obs = owner
          _ <- exercise (toInterfaceContractId @IBaz bazCid) IBaz_Exe with subInformee = subInformee
          pure ()

    -- Never called choice
    -- Added to test support of unvetted dependency in TAPS
    -- See SystematicTopologyAwareUpgradingIntegrationTest
    choice Foo_GetIBar: IBarView
      controller owner
        do
          error "Not implemented"
